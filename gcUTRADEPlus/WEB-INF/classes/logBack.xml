<configuration debug="true">
        <property scope="context" name="LOGIN_LOG" value="/home/tomcat/logs/gcUTRADEPlus/loginController/"/>
        <property scope="context" name="REGISTER_LOG" value="/home/tomcat/logs/gcUTRADEPlus/registerController/"/>
        <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
                <!-- encoders are  by default assigned the type
                        ch.qos.logback.classic.encoder.PatternLayoutEncoder -->
                <encoder>
                        <pattern>%d{HH:mm:ss.SSS} %level - %msg%n</pattern>
                </encoder>
        </appender>
        <appender name="LOGIN" class="ch.qos.logback.core.rolling.RollingFileAppender">
                <file>${LOGIN_LOG}/debug.log</file>
                <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
                        <Pattern>
                                %d{yyyy-MM-dd HH:mm:ss} - %msg%n
                        </Pattern>
                </encoder>
                <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
                        <!-- rollover daily -->
                        <fileNamePattern>${LOGIN_LOG}/archived/debug.%d{yyyy-MM-dd}.%i.log
                        </fileNamePattern>
                        <timeBasedFileNamingAndTriggeringPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
                                <maxFileSize>250MB</maxFileSize>
                        </timeBasedFileNamingAndTriggeringPolicy>
                </rollingPolicy>
        </appender>
        <appender name="REGISTER" class="ch.qos.logback.core.rolling.RollingFileAppender">
                <file>${REGISTER_LOG}/debug.log</file>
                <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
                        <Pattern>
                                %d{yyyy-MM-dd HH:mm:ss} - %msg%n
                        </Pattern>
                </encoder>
                <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
                        <!-- rollover daily -->
                        <fileNamePattern>${REGISTER_LOG}/archived/debug.%d{yyyy-MM-dd}.%i.log
                        </fileNamePattern>
                        <timeBasedFileNamingAndTriggeringPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
                                <maxFileSize>250MB</maxFileSize>
                        </timeBasedFileNamingAndTriggeringPolicy>
                </rollingPolicy>
        </appender>
        <logger name="com.n2n.rest.LoginController" level="debug">
                <appender-ref ref="LOGIN"/>
        </logger>
        <logger name="com.n2n.rest.RegisterController" level="debug">
                <appender-ref ref="REGISTER"/>
        </logger>
        <root level="off"></root>
</configuration>
