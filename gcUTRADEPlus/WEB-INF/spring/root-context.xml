<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:context="http://www.springframework.org/schema/context"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd
		http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context-3.1.xsd">
	
	<context:annotation-config />
	
	<!-- Root Context: defines shared resources visible to all other web components -->
	<context:component-scan base-package="com.google.common.cache." />
	<context:component-scan base-package="com.n2n.login.service"/>
    <!-- Define LoginService with constructor arguments -->
    <bean id="loginService" class="com.n2n.login.service.LoginService">
        <constructor-arg ref="keyCache"/>
        <constructor-arg ref="saltCache"/>
        <constructor-arg ref="ivCache"/>
    </bean>

	<bean id="cacheBuilder" class="com.google.common.cache.CacheBuilder" factory-method="from">
		<constructor-arg type="java.lang.String" value="maximumSize=42, expireAfterAccess=10m, expireAfterWrite=1h"/>
	</bean>
	
	<bean id="eKeyCache" factory-bean="cacheBuilder" factory-method="build" depends-on="cacheBuilder"/>
	<bean id="eSaltCache" factory-bean="cacheBuilder" factory-method="build" depends-on="cacheBuilder"/>
	<bean id="eIvCache" factory-bean="cacheBuilder" factory-method="build" depends-on="cacheBuilder"/>
	
	<bean id="dKeyCache" factory-bean="cacheBuilder" factory-method="build" depends-on="cacheBuilder"/>
	<bean id="dSaltCache" factory-bean="cacheBuilder" factory-method="build" depends-on="cacheBuilder"/>
	<bean id="dIvCache" factory-bean="cacheBuilder" factory-method="build" depends-on="cacheBuilder"/>
	
	<bean id="keyCache" factory-bean="cacheBuilder" factory-method="build" depends-on="cacheBuilder"/>
	<bean id="saltCache" factory-bean="cacheBuilder" factory-method="build" depends-on="cacheBuilder"/>
	<bean id="ivCache" factory-bean="cacheBuilder" factory-method="build" depends-on="cacheBuilder"/>

	<bean id="cacheBuilder1" class="com.google.common.cache.CacheBuilder" factory-method="from">
                <constructor-arg type="java.lang.String" value="maximumSize=42, expireAfterAccess=2h, expireAfterWrite=2h"/>
        </bean>

        <bean id="tokenKeyCache" factory-bean="cacheBuilder1" factory-method="build" depends-on="cacheBuilder1"/>
        <bean id="pubKeyCache" factory-bean="cacheBuilder1" factory-method="build" depends-on="cacheBuilder1"/>

	
	<bean id="dataSource" class="org.springframework.jdbc.datasource.DriverManagerDataSource">
		<property name="driverClassName" value="net.sourceforge.jtds.jdbc.Driver"></property>
		<property name="url" value="jdbc:jtds:sqlserver://fdnewsdb:1433;DatabaseName=PLC"></property>
		<property name="username" value="webuser"></property>
		<property name="password" value="Forsponly@#!"></property>
	</bean>
	<bean id="jdbc" class="org.springframework.jdbc.core.JdbcTemplate">
		<property name="dataSource" ref="dataSource" />
	</bean>
</beans>
