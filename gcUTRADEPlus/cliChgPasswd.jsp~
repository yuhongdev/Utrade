<!--ATP Change Password-->
<script language='javascript'>
var m_nSubmitCount = new Number(0);
function init() {
//	lang('pwdreg_minchar', emoreg_minchar);
}
function getItem(objName) {
	 if (navigator.appName.indexOf("Microsoft") != -1) {
		 return window[objName];
	 } else {
		 return document[objName];
	 }
}
function verifyPwdEntry(oField) {
	var sOldPwd = oField[0];
	var sNewPwd = oField[1];
	var sNewCfmPwd = oField[2];

	//make sure old and new PIN diff
	if (sOldPwd.toLowerCase() == sNewPwd.toLowerCase()) {
		alert("Your new password should not be the same as old password.");
		return false;
	}
	
	if(sNewPwd.length < 6) {
        	alert("Password must be minimum 6 characters")
	        return false;
	}

	var iChars = "%^&*()+=-[]\\\';,./{}|\":<>?";
		for (var i = 0; i < document.frmChgPwd.txtNewPwd.value.length; i++) {
		        if (iChars.indexOf(document.frmChgPwd.txtNewPwd.value.charAt(i)) != -1) {
		                alert ("Only 0-9, A-Z, a-z and four special characters (!@#$) are allowed for password. ");
		                document.frmChgPwd.txtNewPwd.focus();
		                return false;
		        }
              }
	
	//make sure new and conf Pass match
	//if (sNewPwd.toLowerCase() != sNewCfmPwd.toLowerCase()) {
	//	alert("New password does not match confirmation password");
	//	return false;
	//}
	//else 
	if (sNewPwd != sNewCfmPwd) {
		alert("Please make sure new password and confirmation are exactly the same. Passwords are also CASE SENSITIVE.");
		return false;
	}
	
	return true;
}

function checkRequiredFields(oField, vsLang) {
	var fieldNames = new Array("Old Password", "New Password", "Confirm New Password");
	var fieldCheck   = true;
	var fieldsNeeded = " A value must be entered in the following field(s) :\n ";

	for(var nField=0; nField < fieldNames.length; ++nField) {
		if (JStrim(oField[nField]) == "") {
			fieldsNeeded += fieldNames[nField] + " . ";
			fieldCheck = false;
		}
	}

	if (!fieldCheck) {
		// SOME REQUIRED FIELDS ARE MISSING VALUES
		if(JStrim(oField[0]) == "")             //if user id value is missing
		{
		 document.frmChgPwd.txtOldPwd.focus();  
		}
		else if(JStrim(oField[1]) == "")
		{
		 document.frmChgPwd.txtNewPwd.focus();
		}
		else if(JStrim(oField[2]) == "")
		{
		 document.frmChgPwd.txtNewCfmPwd.focus();
		} 
		alert(fieldsNeeded);
	}
	if (fieldCheck) 
	{
		return (verifyPwdEntry(oField));
	}
	return false;
}

function entryVerify(voFrm, vsLang) {
	var oField = new Array("txtOldPwd", "txtNewPwd", "txtNewCfmPwd");
	if (voFrm != null) {
		for (var nField=0; nField < oField.length; ++nField) {
			oField[nField] = voFrm.elements[oField[nField]].value;
		}
	}
	if (checkRequiredFields(oField, vsLang)) {
		return true;
	}
 	return false;
}

function frmSubmit(voFrm, vsLang) {	
	if (entryVerify(voFrm, vsLang)) {		
		if (m_nSubmitCount ==0) {
			<% session.setAttribute("FromURL","changePassword"); %>
			voFrm.action="<%=g_sPath%>/loginATP?action=<%=oN2NSession.getSetting("ForceChgPwdActionString")%>";
			voFrm.submit();
			m_nSubmitCount++;
			return true;
		} else {
			alert("Your request has been submitted. Please wait...");
			return false;
		}		
	}
	else {
		return false;
	}
}
function frmLogout(voFrm, vsLang) {
	voFrm.action="<%=g_sPath%>/loginATP?action=<%=oN2NSession.getSetting("LogoutActionString")%>";
	voFrm.submit();
}
function btnCancel_onClick(voFrm,indicatorChgPwd) {
	if (indicatorChgPwd == "success") {
		voFrm.action="<%=g_sPath%>/loginATP?action=<%=oN2NSession.getSetting("LogoutActionString")%>&from_path=applet";
		voFrm.submit();
		window.close();
	} else {
		window.close();
	}
}

function validatePass(voFrm) {
    var emoreg_password = "Password";
    var emoreg_password_str = "Password Strength";
    var emoreg_password_short = "Too Short";
    var emoreg_password_weak = "Weak";
    var emoreg_password_fair = "Fair";
    var emoreg_password_good = "Good";
    var emoreg_password_strong = "Strong";
    var emoreg_minchar = "Case sensitive. Min. 6 characters. <br>(Best to have a combination of lowercase, uppercase letters and numbers.)"
    var emoreg_confirm_password = "Password (Confirm)";
    var oldPass = voFrm.txtOldPwd.value;
    var newPass = voFrm.txtNewPwd.value;

    var status = validatePassword(newPass, oldPass);

    var passStr = document.getElementById("passStr");
    var weakPass = document.getElementById("weakPass");
    var fairPass = document.getElementById("fairPass");
    var goodPass = document.getElementById("goodPass");
    var strongPass = document.getElementById("strongPass");

    if(status == -1) {
        passStr.innerHTML = emoreg_password_short;
        passStr.style.color = "#C0C0C0";
        weakPass.style.backgroundColor = "#D0D0D0";
        fairPass.style.backgroundColor = "#D0D0D0";
        goodPass.style.backgroundColor = "#D0D0D0";
        strongPass.style.backgroundColor = "#D0D0D0";
//        voFrm.submitChgPwd.disabled=true;        
    } else if(status == 3) {
        passStr.innerHTML = emoreg_password_weak;
        passStr.style.color = "#C80000";
        weakPass.style.backgroundColor = "#C80000";
        fairPass.style.backgroundColor = "#D0D0D0";
        goodPass.style.backgroundColor = "#D0D0D0";
        strongPass.style.backgroundColor = "#D0D0D0";
//        voFrm.submitChgPwd.disabled=true;          
    } else if(status == 2) {
        passStr.innerHTML = emoreg_password_fair;
        passStr.style.color = "#FFCC33";
        weakPass.style.backgroundColor = "#FFCC33";
        fairPass.style.backgroundColor = "#FFCC33";
        goodPass.style.backgroundColor = "#D0D0D0";
        strongPass.style.backgroundColor = "#D0D0D0";
//        voFrm.submitChgPwd.disabled=true;         
    } else if(status == 1) {
        passStr.innerHTML = emoreg_password_good;
        passStr.style.color = "#6699CC";
        weakPass.style.backgroundColor = "#6699CC";
        fairPass.style.backgroundColor = "#6699CC";
        goodPass.style.backgroundColor = "#6699CC";
        strongPass.style.backgroundColor = "#D0D0D0";
//        voFrm.submitChgPwd.disabled=true;          
    } else {
        passStr.innerHTML = emoreg_password_strong;
        passStr.style.color = "#009900";
        weakPass.style.backgroundColor = "#009900";
        fairPass.style.backgroundColor = "#009900";
        goodPass.style.backgroundColor = "#009900";
        strongPass.style.backgroundColor = "#009900";
//        voFrm.submitChgPwd.disabled=false;         
    }
}

</script>

