            }
        };
        qcFeed.request({
            action: 'context',
            callback: _getContext
        });
    }

    function _formatVSearchKey(key) {
        // Escape
        key = key.trim();
        var txt = key.replace(/[-[\]{}()*+?.,\\^$|#\s]/g, "\\$&");
        return '(?i:^' + txt + '[\\s\\S]*)';
    }

    function _convertVSortKey(key) {
        var vKey = key;
        switch (key) {
            case '38': // symbol
                vKey = 'stkCode';
                break;
            case fieldStkCode:
                vKey = 'stkNo';
                break;
        }

        return vKey;
    }

    function _formatVertxInfo(info, exchCode) { // Temporarily used // TODO to be revised
        var vertxInfo = null;
        if (info.data != null && info.data.exchInfos != null) {
            var ex = new Array();
            var sec = new Array();
            var bi = new Array();
            var bl = new Array();
            var exchInfos = info.data.exchInfos;
            var qcParams = new Array();

            for (var exch in exchInfos) {
                // Exchange
                ex.push({
                    ex: exch,
                    ix: exchInfos[exch]['indices'],
                    name: ""
                });

                // Market
                for (var market in exchInfos[exch]['marketInfos']) {
                    sec.push({
                        1: exchInfos[exch]['marketInfos'][market],
                        2: '',
                        3: '',
                        4: '',
                        ex: exch,
                        sc: market
                    });
                    }
                // Fixed: order in some browsers
                sec.sort(jsutil.getArraySorter('sc'));

                if (exch === exchCode) {
                    // Sector
                    for (var sector in exchInfos[exch]['sectorInfos']) {
                        var bid = exchInfos[exch]['sectorParents'][sector];

                        if (bid != "0") {
                            bi.push({
                                bid: bid,
                                ex: exch,
                                id: sector,
                                n: exchInfos[exch]['sectorInfos'][sector]
                            });
                        } else {
                            bl.push({
                                ex: exch,
                                id: sector,
                                n: exchInfos[exch]['sectorInfos'][sector]
                            });
                        }
                    }
                }
                
                if(qcParams.length < 1){
                	qcParams = exchInfos[exch]['qcParams'];
                }
            }
            
            // sorts to avoid inconsistency in some browsers
            ex.sort(jsutil.getArraySorter('ex'));
            bi.sort(jsutil.getArraySorter('id', parseInt));
            bl.sort(jsutil.getArraySorter('id', parseInt));
            
            vertxInfo = {
                login: {
                    ex: ex,
                    sec: sec, // markets
                    s: info.success,
                    t: 'g'
                },
                sector: {
                    bi: bi, // individual sector
                    bl: bl, // sector parent
                    s: info.success,
                    t: 'sec'
                },
                qcParams: qcParams
            };
        }
        
        return vertxInfo;
    }
    
    function _getMarketList(exch) {
