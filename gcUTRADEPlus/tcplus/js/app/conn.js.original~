        if (request.key) {
            // use live feed for historical data
            if (stockutil.isDelayStock(request.key)) {
                request.key = stockutil.removeStockDelay(request.key);
            }
            if (request.count == null) {
                request.count = 50; // default
            } else {
                request.count = parseInt(request.count);
            }
            if (request.period == null) {
                request.period = 7; // default
            } else {
                request.period = parseInt(request.period);
            }
            // prepares param
            var params = new Array();
            params.push(request.key);
            params.push(request.period);
            params.push(0);
            params.push(0);
            params.push(request.count);
            params.push(0); // fixed empty data issue with daily
            params.push(0);

            var reqObj = {
                action: 'qc',
                req: 'Chart',
                type: 'json',
                params: {},
                exch: stockutil.getExchange(request.key),
                callback: function(qc, cfg, res) {
                    var response = {
                        s: res.success
                    };
                    if (res.success) {
                        if (res.data != null) {
                            if (res.data.length > 0) {
                                res.data.splice(0, 1);
                            }
                        } else {
                            res.data = [];
                        }
                        response.d = res.data;
                    } else {
                        response.m = res.message;
                    }

                    if (request.success) {
                        request.success(response);
                    }
                }
            };
            reqObj.params['[ReadData]'] = params.join(",");

            // sends request
            qcFeed.request(reqObj);
        }
    }

    /**
     * Gets business done data from vertx
     * 
     * @param {object} request
     * 
     */
    function getBusinessDone(request) {
        if (!request.hasOwnProperty('ex')) {
            // gets exchange from stock code
            request.ex = stockutil.getExchange(request.k);
        }

        var params = new Array();
        params.push(0);
        params.push(request.ex);
        params.push(request.k);
        params.push(10);
        params.push(10);

        var reqObj = {
            action: "qc",
            req: 'BusinessDone',
            type: 'json',
            params: {}
        };

        reqObj.params[params.join(",")] = '';
        reqObj.exch = request.ex;
        reqObj.callback = function(qc, cfg, res) {
            var response = {
                s: res.success,
                t: 'e'
            };

            if (res.success) {
                response.d = [];
                for (var i in res.data) {
                    var buss = res.data[i];
                    
                    if (buss['0'] == '[TOTAL]' || isNaN(buss['0'])) { // buss['0']=NaN suspected to be an exception from jqc
                        break;
                    }

                    var tempBuss = new Object();
                    for (var j = 0; j < 5; j++) {
                        if (j > 0 && j < 4) { // buy vol, sell vol, total vol, value
                            tempBuss[String(j + 1)] = getLotUnit(buss[String(j)], request.lotSize);
                        } else {
                            tempBuss[String(j + 1)] = buss[String(j)];
                        }
                    }
                    // Sell Vol %
                    tempBuss['6'] = stockutil.getSellRate(tempBuss['2'], tempBuss['4']);
                    // Buy Vol %
                    tempBuss['7'] = stockutil.getBuyRate(tempBuss['3'], tempBuss['4']);

                    response.d.push(tempBuss);
                }

                response.c = response.d.length;
                response.k = request.k;
            } else {
                response.m = res.message;
            }
            
            request.success(response);
        };

        // Sends request
        qcFeed.request(reqObj);
    }

