    function getStockList(request) {
        var columns = stockutil.filterCols(request.f, request.skipMDColCheck);

        if (columns.col05.length > 0) {
            var reqObj = {
                action: 'query',
                coll: ['05'],
                start: parseInt(request.p * request.c),
