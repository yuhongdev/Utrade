                    request.success(response);

                    var codeList = stockutil.getCodeList(res.data);
                    queryFeed06(codeList, columns.col06);
                    queryFeed17(codeList, columns.col17);
                }
            };
            
            if (request.filterWarrant) {
                reqObj.filter.push(
                        {
                            'not': [
                                {or: [
                                        {field: fieldWarrantType, value: warrantCodes, comparison: 'in'},
                                        {'and': [
                                                {field: fieldWarrantType, value: 4999, comparison: 'gt'},
                                                {field: fieldWarrantType, value: 10000, comparison: 'lt'}
                                            ]
                                        }
                                    ]
                                }
                            ]
                        }
                );
            }

            if (request.hasOwnProperty('list') && request.list != null) {
                // if stock list is provided, just ignore exchange, sector, market
                reqObj.filter.push({field: fieldStkCode, value: request.list, comparison: 'in'});
            } else {
                var excFilter = true;
                if (request.secList == "9995") { // New listing
                    reqObj.filter.push({field: fieldStatus, value: '.N(.)*', comparison: 'regex'});
                } else if (request.secList == "9999") { // entitlement
                            reqObj.filter.push({field: fieldStatus, value: '....[CX](.)*', comparison: 'regex'});
                } else if (request.secList == "9998") {
                            // suspended
                            reqObj.filter.push({field: fieldStatus, value: '.S(.)*', comparison: 'regex'});
                        } else {
                    excFilter = false;
                        }

                if (excFilter) {
                    // reset some filter since above sector list do not really exist
                    request.secList = null;
                    request.sec = null;
                    }
                }

            if (request.hasOwnProperty('sorters') && request.sorters != null) {
                reqObj.sort = request.sorters;
            }

            // Sends request
            if (_isConnected()) {
                // qcFeed.request(reqObj);
                qcFeed.query(request.ex, request.mkt, request.secList, request.sec, reqObj);
            }
        } else if (columns.col06.length > 0 && request.list) {
            queryFeed06(request.list, columns.col06);
        } else if(columns.col17.length > 0 && request.list) {
            queryFeed17(request.list, columns.col17);
        }
    }
    
