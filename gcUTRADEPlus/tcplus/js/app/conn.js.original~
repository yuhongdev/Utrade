    function initInfoData(dataObj) {
        debugutil.debug('conn > initInfoData');

        if (!isMobile) {
            Ext.suspendLayouts();
        }

        if (indexCodes.length > 0) {
            indexCodes = [];
        }

        var ex = feedLoginRet.ex;
        var tempExObj = null;
        var subObj = null;
        if (arExMapping && arExMapping.scpt) {
            subObj = arExMapping.scpt;
        }
        
        if(dataObj.qcParams['[TP]']){
        	var tempData = dataObj.qcParams['[TP]'][0].split('|');
        	for(var i=0; i<tempData.length; i++){        		
        		var tpCode = tempData[i].substring(0, tempData[i].indexOf('-')).trim();
        		var tpName = tempData[i].substring(tempData[i].indexOf('-') + 1).trim();
        		
        		var tpObj = {};
        		tpObj.code = tpCode;
        		tpObj.name = tpName;
        		global_TPMapping.push(tpObj);
        	}
        }

        if (subObj != null) {
            // get exchange name from subscription data
            var subArr = subObj; //.subs;
            var totSubs = subArr.length;
            for (var i = 0; i < totSubs; i++) {
                var sub = subArr[i];
                var totEx = ex.length;

                for (var j = 0; j < totEx; j++) {
                    var exchg = ex[j];
                    var code = exchg.ex;
                    var name = '';
                    //allow to view singapore exchange if LMS subscribe to SI/SG
                    //production
                    if (sub.ex == code || (sub.ex == 'SI' && code == 'SG')) {	// match with ATP

                        //bypass
                        //if ( sub.ex.indexOf(code)>=0 || (sub.ex == 'SI' && code == 'SG')) {	// match with ATP
                        var isDuplicate = false;
                        for (var ii = 0; ii < indexCodes.length; ii++) {
                            if (code == (indexCodes[ ii ]).ex) {
                                isDuplicate = true;
                            }
                            
                            if(indexCodes[ii].ex == global_confDefaultViewEx){
                            	tempExObj = indexCodes[ii];
                            }
                        }

                        if (!isDuplicate) {
                            if (code == 'SGi')
                                continue;
                            else
                                name = getExchangeFullName(code);
                        	
                            //exchg.name = sub.exn + ' (' + sub.ex + ')';
                        	exchg.name = name;
                            if (canView(code)) {
                                if (bypassMYAccChecking == 'FALSE') {
                                    if ((authenret.atp.sct == 'M' || authenret.atp.sct == 'C') && code == 'MY')
                                        if (!haveActiveAcc(code))
                                            continue;
                                    indexCodes.push(exchg);
                                } else {
                                    indexCodes.push(exchg);
                                }
                                this.colRDTooltip = languageFormat.getLanguage(30129, 'R = Real time <br/> D = Delayed > 15 minutes');
                            }

                        }
                        break;
                    }
                }
            }
        } else {
            // hardcoded name
            var totEx = ex.length;
            for (var i = 0; i < totEx; i++) {
                exchg = ex[i];
                var name = '';
                var code = exchg.ex;
                
                if (code == 'SGi')
                    continue;
                else
                    name = getExchangeFullName(code);
                
                exchg.name = name;

                /*
                 * authenret.atp.sct 
                 * 
                 * 	M : end user 
                 *  D : dealer
                 *  R : 
                 * 
                 * 
                 * canView(code)  : check the user have permission to view exchange code
                 * 
                 * haveActiveAcc(code) : verify the user have account for the exchange code 
                 */
                if (canView(code)) {
                    if (global_HaveATP.toLowerCase() == 'true') {
                        if (bypassMYAccChecking == 'FALSE') {
                            if (authenret.atp.sct == 'M' || authenret.atp.sct == 'C') {
                                if (code == 'MY') {
                                    if (!haveActiveAcc(code))
                                        continue;
                                    indexCodes.push(exchg);
                                } else {
                                    indexCodes.push(exchg);
                                }

                            } else {
                                indexCodes.push(exchg);
                            }
                        } else {
                            indexCodes.push(exchg);
                        }
                    } else {
                        indexCodes.push(exchg);
                    }
                }
            }
        }
        
        // no need manual sort but backend have sort by country code
        if (N2N_CONFIG.sortExchangeList) {

            indexCodes.sort(jsutil.getArraySorter('name'));
            // move default exchange to the first position
            if (tempExObj) {
                for (var i = 0; i < indexCodes.length; i++) {
                    var exObj = indexCodes[i];
                    if (exObj.name === tempExObj.name) {

                        indexCodes.splice(i, 1);
                        indexCodes.unshift(tempExObj);
                        break;
                    }
                }
            }

        }

        var exchangeMenu = new Array();
        var exchCount = indexCodes.length;
        var productMenu = [];
