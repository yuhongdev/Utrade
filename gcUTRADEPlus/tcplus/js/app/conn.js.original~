/**
 * Provides websocket connection to vertx
 */

var conn = function() {
    var qcFeed;
    // listener IDs
    var listen05 = "listen05";
    var listen06 = "listen06";
    var listen17 = "listen17";
    var listenFundamental = "listenFundamental";
    var listenStockInfo06 = "listenStockInfo06";
    var listenWi = "listenWi";
    var listenNormalMD = "listenMD";
    var listenMultiMD = "listenMultiMD";
    var listenMkt = 'listenMkt';
    var listenInd = 'listenInd';
    var listenTime = 'listenTime';
    var listenTran = 'listenTran';
    var listen18 = 'listen18';
    var subColl = {};
    var connectionRetry = vertxAutoRetry;
    var stkcodes = new Array();
    var fieldlists = new Array();
    var prevStkCodes = new Array();
    var prevFieldList = new Array();
    var prevNormalMDList = new Array();
    var prevMultiMDList = new Array();
    var indicesList = []; // to cache subscribed indices codes
    var marketCodes = {}; // to cache retrieving market code
    var subscriptionTask;
    var keepAliveRetry = 3;
    var keepAliveTask = null;
    var keepAliveTimer = null;
    var logoutErrorCode = null;
    var notified = false;
    var infoInit = false;
    var vertxAutoConnectTask = null;
    var exchangeInfo = null;
    var normalURLs = new Array();
    var outboundURLs = new Array();
    var activeIndex = 0;
    var activeServers = new Array();
    var _reqObjs = {}; // cache latest requests by listener
    var warrantCodes = ['8', '16', '17', '19', '20', '31', '32', '35', '36', '37', '38', '39', '40', '41', '42'];
    
    function _addSub(coll) {
        subColl[coll] = true;
    }

    function _deleteSub(coll) {
        delete subColl[coll];
        _reqObjs[coll] = null;
    }
     
    function _getServers() {
        return {
            n: normalURLs,
            ob: outboundURLs
        };
    }
    
    var _isInit = true;
    function _init() {
        var serverURLs = vertxfeed.split(',');
        for (var i = 0; i < serverURLs.length; i++) {
            var addr = serverURLs[i].trim();
            if (addr !== '') {
                if (/^ob:/.test(addr)) {
                    outboundURLs.push(addr.substring(3));
                } else {
                    normalURLs.push(addr);
                }
            }
        }

        if (outbound) {
            activeServers = outboundURLs.concat();
        } else {
            activeServers = normalURLs.concat();
        }

        // to provide compatibility with current config if not already updated 
        if (activeServers.length === 0) {
            if (outboundURLs.length > 0) {
                activeServers.push(outboundURLs[0]);
            }
            if (normalURLs.length > 0) {
                activeServers.push(normalURLs[0]);
            }
        }

        _isInit = false;
    }
    
    function connect() {
        if (_isInit) {
            _init();
        }
        
        if (!qcFeed) {
            if (activeServers.length > 0) {
                var qcFeedVertxUrl = formatUrl(activeServers[activeIndex]);
                
                if (activeServers.length > 1) {
                    console.log('Connecting server', activeIndex, '->', qcFeedVertxUrl, '...');
                } else {
                    console.log('Connecting server', qcFeedVertxUrl);
                }

                var t5 = new Date().getTime();

                // Creates qcFeed connection
                qcFeed = new QcFeed(qcFeedVertxUrl + '/eventbus', {
                    debug: N2N_CONFIG.fDebug,
                    devel: false
                });
                
                // add centralized feed listener
                qcFeed.addFeedListener({
                    listenId: 'VListener',
                    callback: updateHandler
                });

                qcFeed.onopen = function() {
                    if (N2N_CONFIG.lDebug) {
                        console.log('connected to server in ', (new Date().getTime() - t5) / 1000, 's');
                        t5 = null;
                    }
                    if (topPanelBar != null) {
                        topPanelBar.setSignal('Online');
                    }
                    
                    // Resets connection retry back to 3
                    connectionRetry = vertxAutoRetry;
                };

                qcFeed.onclose = function() {

                    if (!onRefreshBrowser) {
                        if (connectionRetry > 0) {
                            connectionRetry -= 1;
                            autoReconnect();
                        } else if (activeServers[++activeIndex]) {
                            connectionRetry = vertxAutoRetry;
                            console.log('Could not connect server', activeIndex - 1);
                            disconnect();
                            connect();
                        } else {
                            if (topPanelBar != null) {
                                topPanelBar.setSignal();
                            }
                            conn.notifySession("{t: 'local', d: 'feeddown'}");
                        }
                    }
                    
                };
            } else {
                msgutil.error('Sorry, no feed server is available.', conn.logout, false);
                return;
            }
        }

        if (!_isConnected() && !notified) {
            if (topPanelBar != null) {
                topPanelBar.setSignal('Loading');
            }
            // Connects to vertx
            if (!infoInit) {
                qcFeed.connect(function() {
                    _configureSession(_getInfo);
                }); // Don't pass with ()
            } else {
                // reconnect without getting info
                qcFeed.connect(function() {
                    _configureSession(function() {
                        if (streaming) {
                            _subscribeAll();
                        }
                    });
                });
            }
        }
    }
    
    function _configureSession(callback) {
        if (!jsutil.isEmpty(defVToken)) {
            vToken = defVToken;
        }
        
        if (vToken == null) {
            Ext.Ajax.request({
                url: addPath + 'tcplus/getvtoken',
                success: function(response) {
                    if (response.responseText) {
                        try {
                            var resObj = Ext.decode(response.responseText);
                            if (resObj.s) {
                                vToken = resObj.v;
                            }
                        } catch (e) {
                        }
                    }
                },
                callback: function() {
                    if (vToken) {
                        connectionRetry = vertxAutoRetry;
                        _configureSession(callback);
                    } else {
                        if (connectionRetry > 0) {
                            connectionRetry -= 1;
                            _configureSession(callback);
                        } else {
                            debugutil.debug('Could not get vtoken.');
                            conn.notifySession("{t: 'local', d: 'err'}");
                        }
                    }
                }
            });

            return;
        }
        
        if (qcFeed) {
            qcFeed.request({
                action: 'session',
                numAsStr: true,
                user: loginId + '@' + sponsorID + '_' + sView,
                token: vToken,
                callback: function(qc, cfg, res) {
                    // clears vtoken
                    vToken = null;

                    if (res.success) {
                        connectionRetry = vertxAutoRetry;
                        if (typeof callback === 'function') {
                            callback();
                        }
                    } else {
                        if (connectionRetry > 0) {
                            debugutil.debug('Failed to configure session');
                            setTimeout(function() {
                                _configureSession(callback);
                            }, 100);
                            connectionRetry -= 1;
                        } else {
                            debugutil.debug('Could not configure session');
                            conn.notifySession("{t: 'local', d: 'err'}");
                        }
                    }
                }
            });
        }
    }

    function autoReconnect() {
        if (vertxAutoConnect) {
            debugutil.debug('conn > autoConnect (to vertx)...');

            if (topPanelBar != null) {
                topPanelBar.setSignal('Loading');
            }
            clearAutoConnectTask();
            var retryMsg = vertxAutoConnect / 1000 + 's';
            debugutil.debug('Retry in ' + retryMsg + '...');
            vertxAutoConnectTask = setTimeout(function() {
                connect();
            }, vertxAutoConnect);
        }
    }

    function notifyConnectionLost() {
        msgutil.show({
            msg: languageFormat.getLanguage(31111, 'We regret to inform that we are unable to connect to server at this time. Please try again later.'),
            buttons: Ext.MessageBox.OK,
            buttonText: {
                ok: MSG.OK
            },
            fn: function(btn) {
                if (btn == 'ok') {
                }
            }
        });
    }

    function clearAutoConnectTask() {
        if (vertxAutoConnectTask) {
            clearInterval(vertxAutoConnectTask);
            vertxAutoConnectTask = null;
        }
    }

    function _isConnected() {
        return qcFeed != null && qcFeed.isConnected();
    }

    function disconnect() {
        if (_isConnected()) {
            qcFeed.close();
        }
        qcFeed = null;
    }

    function logout() {
        var url = '';

        if (logoutDeviceDetection == "TRUE") {
            if (isTablet || isPhone) {
                url = logoutURLLite;
            } else {
                url = logoutURLOthers;
            }
        } else {
            url = logoutURLLite;
        }

        if (parent)
            parent.document.location = url;
        else
            document.location = url;
    }

    function requestLogout() {
        debugutil.debug('conn > requestLogout');
        
        stopKeepAlive();
        disconnect();
        Ext.Ajax.request({
            url: addPath + 'tcplus/logout?' + logoutErrorCode,
            method: 'POST',
            success: function(response) {
            },
            failure: function(response) {

            }
        });
    }
    
    /**
     * Keeps TCLite session
     */
    function keepAlive(doRelogin) {
        var debugTitle = 'conn > keepAlive';
        var time = N2N_CONFIG.frontKeepAliveInt;

        if (keepAliveRetry <= 0) {
            conn.notifySession("{t: 'local', d: '-999'}");
            return;
        }

        if (keepAliveTask == null) {
            keepAliveTask = {};
        } else {
            keepAliveTask.ajax = null;
            if (keepAliveTask.alive == false) {
                time = 5000;
            }
        }

        var d = new Date();
        var timeStr = d.getHours() + '' + d.getMinutes() + '' + d.getSeconds();
        var url = addPath + 'tcplus/keepalive?' + (doRelogin ? 'dorelogin=true&' : '') + d.getFullYear() + d.getMonth() + d.getDate() + timeStr + '_' + loginId + '_' + N2N_CONFIG.confServerNo;

        debugutil.debug(debugTitle, 'time: ' + timeStr);

        var runKeepAlive = true;
        keepAliveTask.ajax = Ext.Ajax.request({
            url: url,
            method: 'POST',
            success: function(response) {
                /*
                 * success response {t:"a",s:true}
                 * response {e:-999,t:"a",s:false,m:"Session not found"} 
                 */
                debugutil.debug(debugTitle, 'keep alive ok: response ---> ' + response.responseText);

                var obj = null;
                try {
                    obj = Ext.decode(response.responseText);

                    if (obj.s == true) {
                        keepAliveRetry = 3;
                        keepAliveTask.alive = true;
                    } else {
                        if (obj != null) {
                            if ((obj.e == '-999') && (obj.m == 'Session not found')) {
                                // temporarily stop keep alive
                                stopKeepAlive();
                                _relogin();
                            } else {
                                conn.notifySession("{t: 'local', d:'" + obj.e + "' , ms:'" + obj.m + "' }");
                            }
                            runKeepAlive = false;
                        }

                        keepAliveRetry--;
                        keepAliveTask.alive = false;
                    }
                } catch (e) {
                    keepAliveRetry--;
                    keepAliveTask.alive = false;
                }
            },
            failure: function(response) {
                keepAliveRetry--;
                keepAliveTask.alive = false;
                debugutil.debug(debugTitle, 'keep alive failure: response ---> ' + response.responseText);
            },
            callback: function() {
                if (runKeepAlive) {
                    keepAliveTimer = setTimeout(function() {
                        conn.keepAlive();
                    }, time);
                }
            }
        });

    }
    
    function _relogin() {
        var reloginSuccess = false;

        n2nLayoutManager.setLoading('Reconnecting...');
        Ext.Ajax.request({
            url: N2N_CONFIG.reloginURL,
            success: function(response) {
                if (response.responseText != '') {
                    try {
                        var resObj = Ext.decode(response.responseText);
                        if (resObj) {
                            reloginSuccess = true;

                            if (resObj.status > -1) {
                                // starts keepalive again
                                //conn.keepAlive(true);
                            	location.reload();
                            } else {
                                n2nLayoutManager.setLoading(false);
                                var msgObj = {
                                    t: "relogin",
                                    d: "",
                                    ms: resObj.message
                                };
                                conn.notifySession(Ext.encode(msgObj));
                            }
                        }
                    } catch (e) {
                    }
                }
            },
            callback: function() {
                n2nLayoutManager.setLoading(false);
                if (!reloginSuccess) {
                    conn.notifySession("{t: 'local', d: '-999', ms: 'Session not found'}");
                }
            }
        });
    }

    function stopKeepAlive() {
        if (topPanelBar != null) {
            topPanelBar.setSignal("Offline");
        }
        clearTimeout(keepAliveTimer);
        keepAliveTimer = null;
    }

    function notifySession(responseText) {
        var debugTitle = 'conn > notifySession';
        debugutil.debug(debugTitle, 'result ---> ' + responseText);
        
        if (notified) {
            return; // avoid duplicate notified message
        }

        /*
         if (N2NLoginStatus.returnOnAliveSession() == false) {
         return;
         } else {
         N2NLoginStatus.setOnAliveSession(false);
         }
         */

        var obj = null;
        try {
            obj = Ext.decode(responseText);

            var cleanTimer = function() {
                if (orderStatusPanel != null)
                    orderStatusPanel.stopRefreshTimer();
                if (equityPrtfPanel != null)
                    equityPrtfPanel.stopRefreshTimer();
                if (equityManualPrtfPanel != null)
                    equityManualPrtfPanel.stopRefreshTimer();
                if (equityPrtfRealizedPanel != null)
                    equityPrtfRealizedPanel.stopRefreshTimer();
                if (topPanelBarPanel != null)
                    topPanelBarPanel.stopLoopTime();
                if (quoteScreen != null) {
                    quoteScreen.stopAutoRefresh();
                }
                if (newsPanel) {
                    newsPanel.stopRefresh();
                }
            };

            var errorMessage = "";

            if (obj.t == "scsl") {
                errorMessage = obj.ms;
            } else {
                switch (obj.d) {
                    case  'e':
                        errorMessage = languageFormat.getLanguage(31105, 'We regret to inform that your session has expired. Kindly login again.(e)');
                        break;
                    case 's':
                        errorMessage = languageFormat.getLanguage(31106, 'System detected you have login to another computer and this session will be stopped. - 1102 WEB');
                        break;
                    case 't':
                        errorMessage = languageFormat.getLanguage(31107, 'We regret to inform that your session has expired. Kindly login again.(t)');
                        break;
                    case 'loginFail':
                        errorMessage = languageFormat.getLanguage(31108, 'We regret to inform that your login attempt was unsuccessful. Kindly try again shortly.');
                        break;
                    case '-999':
                        errorMessage = languageFormat.getLanguage(31109, 'We regret to inform that we are unable to process your request at this time. Kindly try again shortly.(9)');
                        break;
                    case 'idleMode':
                        errorMessage = languageFormat.getLanguage(31110, 'We regret to inform that we are unable to connect to the server at this time. Kindly check your internet connection and try again.(dwr)');
                        break;
                    case 'feeddown':
                        errorMessage = languageFormat.getLanguage(31111, 'We regret to inform that we are unable to connect to server at this time. Please try again later.');
                        break;
                    case 'err':
                        errorMessage = languageFormat.getLanguage(31112, 'Error occurred.');
                        break;
                    case '-23001':
                        errorMessage = languageFormat.getLanguage(31121, 'We regret to inform that we are unable to process your request at this time. Kindly try again shortly.(23001)');
                        break;
                    default:
                        errorMessage = obj.ms;
                }



            }

            cleanTimer();
            stopKeepAlive();
            onRefreshBrowser = true;
            conn.disconnect();
            if (n2nTicker != null) {
                n2nTicker.stop();
            }

            logoutErrorCode = "ErrorType=";
            if (obj.t != null) {
                logoutErrorCode += obj.t;
            }
            logoutErrorCode += "&ErrorCode=";
            if (obj.d != null) {
                logoutErrorCode += obj.d;
            }
            logoutErrorCode += "&ErrorMessage=";
            if (errorMessage != null) {
                logoutErrorCode += errorMessage;
            }

            n2nLayoutManager.setLoading(false);
            if (cookies.readCookie(loginId + '_defTrAccSync') == 'false') {
                n2ncomponents.requestSaveDefaultTradingAccountSetting(false);
            }
            msgutil.error(n2br(errorMessage), conn.logout);
            notified = true;

        } catch (e) {
            debugutil.debug(debugTitle, 'exception ---> ' + e, e, true);
        }
    }

    function _request(reqObj) {
        if (_isConnected()) {
            qcFeed.request(reqObj);
        }
    }

    function updateHandler(qc, lis, res) {

        if (res.data) {
            switch (res.data[fieldMsgType]) {
                case 'A05':
                case 'U05':
                    // Update quote
                    var qd = _formatSingleVertxData(res, typeQuote, null, formatData05);
                    updater.updateQuote(qd);
                    updater.updatePriceAlert(qd);
                    
                    if (n2ncomponents.worldIndices) {
                        n2ncomponents.worldIndices.updateFeedRecord(res.data);
                    }

                    break;
                case 'A06':
                case 'U06':
                    // Update quote
                    var qd = _formatSingleVertxData(res, typeQuote, '666');
                    updater.updateQuote06(qd);

                    break;
                case 'U12':
                    var qd = _formatSingleVertxData(res, typeQuote);
                    updater.updateQuote12(qd);

                    break;
                case 'U09':
                    var fd = _formatSingleVertxData(res, 't');
                    updater.updateTime(fd);

                    break;
                case 'A01':
                case 'U01':
                    var fd = _formatSingleVertxData(res, typeIndex);
                    updater.updateSummary(fd);

                    break;
                case 'A02':
                case 'U02':
                    var fd = _formatSingleVertxData(res, typeScoreBoard, null, formatData02);
                    updater.updateSummary(fd);

                    break;
                case 'A07':
                case 'U07':
                    if (marketStreamer) {
                        marketStreamer.updateFeedRecord(res.data);
                    }

                    if (trackerRecord) {
                        trackerRecord.updateFeedRecord(res.data);
                    }

                    break;
                case 'A18':
                case 'U18':
                    for (var i = 0; i < n2ncomponents.brokerQViews.length; i++) {
                        n2ncomponents.brokerQViews[i].updateFeedRecord(res.data);
                    }
                    
                    break;
            }
        }
    }

    function subscribeFeed(forceSubscribe) {
        if (t1) {
            console.log('load spent in ', (new Date().getTime() - t1) / 1000, 's');
            t1 = null;
        }
        
        if (conn.isConnected()) {
            stkcodes.sort();
            fieldlists.sort();
            
            if (stkcodes.length === 0) {
                fieldlists = [];
            }
            
            if (forceSubscribe || (stkcodes.join(',') !== prevStkCodes.join(',') || fieldlists.join(',') !== prevFieldList.join(','))) {
                prevStkCodes = stkcodes.concat();
                prevFieldList = fieldlists.concat();

                if (stkcodes.length > 0) {
                    var columns = stockutil.filterCols(fieldlists);

                    if (columns.col05.length > 0) {
                        console.log('conn > subscribeFeed');

                        // Unregister previous subscription (if any)
                        /*
                         qcFeed.request({
                         action: 'unregister',
                         listenId: listen05
                         });
                         */

                        if (forceSubscribe) {
                            columns.col05.push(fieldMsgType);
                        }
                        
                        if (streaming) {
                            // Register feed
                            qcFeed.request({
                                action: 'register',
                                listenId: listen05,
                                coll: ['05'],
                                query: forceSubscribe || false,
                                filter: [
                                    {field: fieldStkCode, value: stkcodes, comparison: 'in'}
                                ],
                                column: jsutil.arrayUnique(columns.col05)
                            });
                        }

                        _addSub(listen05);
                    }

                    if (columns.col06.length > 0) {
                        if (forceSubscribe) {
                            columns.col06.push(fieldMsgType);
                        }
                        subscribeFeed06(stkcodes, columns.col06, forceSubscribe);
                    }
                    
                    if (columns.col17.length > 0) {
                        if (forceSubscribe) {
                            columns.col17.push(fieldMsgType);
                        }
                        subscribeFeed17(stkcodes, columns.col17, forceSubscribe);
                    }
                } else {
                    qcFeed.request({
                        action: 'unregister',
                        listenId: listen05
                    });
                    qcFeed.request({
                        action: 'unregister',
                        listenId: listen06
                    });
                    qcFeed.request({
                        action: 'unregister',
                        listenId: listen17
                    });
                    
                    _deleteSub(listen05);
                    _deleteSub(listen06);
                    _deleteSub(listen17);
                }
            }

            subscribeMD(forceSubscribe);
        }
    }

