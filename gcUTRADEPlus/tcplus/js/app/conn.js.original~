        				}
        			}
        		});
        	}
        }
        /*
         if (outbound) {
         disableMenuItems(exchangecode);
         }*/

        updateTopMenu();

        if ((showExchangeHeader == "TRUE" && mainMenuBar) || (showExchangeHeader == "TRUE" && N2N_CONFIG.menuType == MENU_TYPE.TOOL)) { // default menu
