    /**
     * Gets transaction data from vertx
     * 
     * @param {object} request
     * 
     */
    function getTransaction(request) {
        var transCount = 100; // Default
        var _end = parseInt(request.end);
        var _total = parseInt(request.total);
        var _begin = 0;
        var _page = 0;
        if (_end != -1) {
            if (stockutil.isDelayStock(request.k)) {
                _page = parseInt(request.p);
                _begin = _page * transCount;
                _end = _begin + (transCount - 1);
            } else {
                _begin = parseInt(request.begin);

                switch (request.eventType) {
                    case 'next':
                        _begin = _begin - transCount;
                        _end = _end - transCount;

                        break;
                    case 'prev':
                        _begin = _begin + transCount;
                        _end = _end + transCount;

                        break;
                    case 'last':
                        _begin = 0;
                        _end = transCount;

                        break;
                }

                if (_end > _total) {
                    _end = _total;
                }
                if (_end - _begin !== transCount) {
                    _begin = _end - transCount;
                }
                if (_begin < 0) {
                    _begin = 0;
                }
            }
        } else {
            _end = 1;
        }

        var reqObj = {
            action: "qc",
            req: 'TRANSACT',
            type: 'json',
            params: {}
        };

        if (request.hasOwnProperty('ex') && request.ex !== null) {
            reqObj.exch = request.ex;
        } else {
            // if no exchange is provided just get it from stock code
            reqObj.exch = stockutil.getExchange(request.k);
        }

        var params = new Array();
        // MUST BE IN THIS ORDER //
        params.push(request.k);
        params.push(0);
        params.push(0);
        params.push(0);
        params.push(_begin);
        params.push(_end);
        if (stockutil.isDelayStock(request.k)) {
            params.push(15);
        }
        if (request.sort != null) {
            params.push(request.sort);
            // count
            params.push(1);
        }

        reqObj['params']['[T]'] = params.join(',');
        if (request.hasOwnProperty('success') && request.success !== null) {
            reqObj.callback = function(qc, cfg, res) {
                var response = {
                    s: res.success,
                    t: 'trans'
                };

                if (res.success) {
                    var tCount = res.data.length;
                    response.info = {};

                    // formats transaction data
                    var transactData = new Array();
                    for (var i in res.data) {
                        var tdata = res.data[i];

                        if (i == 0) {
                            // info
                            var tempInfo = new Object();
                            tempInfo[fieldStkCode] = tdata['0'];
                            tempInfo[fieldTransNo] = tdata['1'];
                            tempInfo[fieldPrev] = tdata['2'];
                            tempInfo[fieldLacp] = tdata['3'];
                            tempInfo[fieldLast] = tdata['4'];
                            tempInfo[fieldVol] = tdata['5'];
                            tempInfo[fieldOpen] = tdata['6'];
                            tempInfo[fieldHigh] = tdata['7'];
                            tempInfo[fieldLow] = tdata['8'];
                            tempInfo[fieldTransDate] = tdata['9'];
                            tempInfo[fieldTransTime] = tdata['10'];

                            response.info = {
                                beginNumber: _begin,
                                endNumber: _end,
                                info: tempInfo,
                                totalCount: tCount - 1
                            };
                        } else {
                            // data
                            var tempObj = new Object();
                            tempObj[fieldTransTime] = tdata['0'];
                            tempObj[fieldTransAction] = tdata['1'];
                            tempObj[fieldLast] = tdata['2'];
                            tempObj[fieldUnit] = getLotUnit(tdata['3'], request.lotSize);
                            tempObj[fieldTransNo] = tdata['5'];
                            
                            if(tdata['6']){
                            	tempObj[fieldBuyType] = tdata['6'];
                                tempObj[fieldBuyBroker] = tdata['7'];
                                tempObj[fieldSellType] = tdata['8'];
                                tempObj[fieldSellBroker] = tdata['9'];
                                tempObj[fieldAmalgamateBroker] = tdata['10'];
                            }else{
                            	tempObj[fieldBuyType] = '-';
                                tempObj[fieldBuyBroker] = '-';
                                tempObj[fieldSellType] = '-';
                                tempObj[fieldSellBroker] = '-';
                                tempObj[fieldAmalgamateBroker] = '-';
                            }
                            
                            
                            transactData.push(tempObj);
                        }
                    }

                    response.c = tCount;
                    response.d = transactData;
                } else {
                    response.m = res.message;
                }

                request.success(response);
            };
        }

        qcFeed.request(reqObj);
    }

