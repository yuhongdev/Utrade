    function _formatJKBkData(dtObj) {
        // domestic
        var dBuyVal = jsutil.getRound(dtObj['10']);
        var dSellVal = jsutil.getRound(dtObj['13']);
        var dBuyVol = dBuyVal ? jsutil.getRound(dtObj['9']) : 0;
        var dSellVol = dSellVal ? jsutil.getRound(dtObj['12']) : 0;
        var dTotalVal = dBuyVal + dSellVal;
        var dNetVal = dBuyVal - dSellVal;
        var dNetVol = dBuyVol - dSellVol;
        var dTotalVol = dBuyVol + dSellVol;
        if (dTotalVal === 0) {
            dNetVol = 0;
        }
        var dBuyFreq = jsutil.getRound(dtObj['11']);
        var dSellFreq = jsutil.getRound(dtObj['14']);
        // foreign
        var fBuyVal = jsutil.getRound(dtObj['4']);
        var fSellVal = jsutil.getRound(dtObj['7']);
        var fBuyVol = fBuyVal ? jsutil.getRound(dtObj['3']) : 0;
        var fSellVol = fSellVal ? jsutil.getRound(dtObj['6']) : 0;
        var fTotalVal = fBuyVal + fSellVal;
        var fNetVal = fBuyVal - fSellVal;
        var fTotalVol = fBuyVol + fSellVol;
        var fNetVol = fBuyVol - fSellVol;
        if (fTotalVal === 0) {
            fNetVol = 0;
        }
        var fBuyFreq = jsutil.getRound(dtObj['5']);
        var fSellFreq = jsutil.getRound(dtObj['8']);
        // total
        var buyVal = dBuyVal + fBuyVal;
        var sellVal = dSellVal + fSellVal;
        var buyVol = dBuyVol + fBuyVol;
        var sellVol = dSellVol + fSellVol;
        var totalVal = buyVal + sellVal;
        var netVal = buyVal - sellVal;
        var totalVol = buyVol + sellVol;
        var netVol = buyVol - sellVol;
        if (totalVal === 0) {
            netVal = 0;
            netVol = 0;
        }
        var buyFreq = dBuyFreq + fBuyFreq;
        var sellFreq = dSellFreq + fSellFreq;
        var totalFreq = buyFreq + sellFreq;

        return {
            'bkCode': dtObj['2'],
            'bkName': '',
            'buyVol': buyVol,
            'buyVal': buyVal,
            'sellVol': sellVol,
            'sellVal': sellVal,
            'totalVal': totalVal,
            'netVal': netVal,
            'totalVol': totalVol,
            'netVol': netVol,
            'buyFreq': buyFreq,
            'sellFreq': sellFreq,
            'totalFreq': totalFreq,
            'dBuyVol': dBuyVol,
            'dBuyVal': dBuyVal,
            'dSellVol': dSellVol,
            'dSellVal': dSellVal,
            'dTotalVal': dTotalVal,
            'dNetVal': dNetVal,
            'dTotalVol': dTotalVol,
            'dNetVol': dNetVol,
            'dBuyFreq': dBuyFreq,
            'dSellFreq': dSellFreq,
            'fBuyVol': fBuyVol,
            'fBuyVal': fBuyVal,
            'fSellVol': fSellVol,
            'fSellVal': fSellVal,
            'fTotalVal': fTotalVal,
            'fNetVal': fNetVal,
            'fTotalVol': fTotalVol,
            'fNetVol': fNetVol,
            'fBuyFreq': fBuyFreq,
            'fSellFreq': fSellFreq
        };
    }
    
