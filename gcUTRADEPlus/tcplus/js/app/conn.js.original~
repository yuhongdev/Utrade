    function _subscribeAll() { // resubscribe all updates
        if (_isConnected()) {
            // Since feed and market depth subscriptions are on the same run, this is to make sure it run only once if both exists
            var feedSubRun = false;
            for (var ln in subColl) {
                switch (ln) {
                    case listen05:
                    case listenNormalMD:
                    case listenMultiMD:
                        if (!feedSubRun) {
                            Storage.refresh(); // in case stock list not updated when switching tab
                            
                            subscribeFeed(true);
                            feedSubRun = true;
                        }

                        break;
                    case listenWi:
                        _subscribeWorldIndices(true);
                        
                        break;
                    case listenMkt:
                        subscribeMarket(true);

                        break;
                    case listenInd:
                        subscribeIndices(indicesList, true);

                        break;
                    case listenTime:
                        subscribeTime();

                        break;
                    case listenTran:
                        subscribeTransaction();

                        break;
                    case listenFundamental:
