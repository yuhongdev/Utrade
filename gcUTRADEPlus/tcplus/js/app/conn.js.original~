/**
 * Formats vertx feed to be reusable with existing functions
 * 
 * @param {object} feed
 * @param {string} tID
 * @param {boolean} roundValue
 * @returns {object}
 */
function _formatVertxData(feed, tID, formatFn) {
    var returnObj = {};

    if (feed) {
        if (feed.success) {
            returnObj.s = feed.success;

            for (var _i in feed.data) {
                var feedData = feed.data[_i];

                if (typeof formatFn === 'function') {
                    formatFn(feedData);
                }

            }

            returnObj.c = feed.data.length; // Count/Number of records
            returnObj.d = feed.data; // data
        } else {
            returnObj.m = feed.message; // message
            returnObj.e = ''; // error?
        }
    }

    if (tID) {
        returnObj['t'] = tID;
    }

    return returnObj;
}

function _formatSingleVertxData(feed, tID, msgType, formatFn) {

    if (typeof formatFn === 'function') {
        formatFn(feed.data);
    }

    if (msgType) {
        var formatData = new Object();
        // append message type as prefix
        for (var i in feed.data) {
            if (i != fieldStkCode) {
                formatData[msgType + i] = feed.data[i];
            } else {
                formatData[i] = feed.data[i];
            }
        }

        feed.data = formatData;
    }

    var fd = {
        s: true,
        d: [feed.data],
        c: 1
    };

    if (tID) {
        fd['t'] = tID;
    }

    return fd;
}

