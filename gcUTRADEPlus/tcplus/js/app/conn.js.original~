    function subscribeTransaction(request) {
        if (conn.isConnected()) {
            var listenId = request.listenId;
            
            if (streaming) {
                // Register transaction
                var reqObj = {
                    action: 'register',
                    listenId: listenId,
                    coll: ['07']
                };

                var filter = [];
                if (request.list) {
                    filter.push({field: fieldStkCode, value: request.list, comparison: 'in'});
                    reqObj.exch = getExchangeFromCodes(request.list);
                } else if (request.exch) {
                    reqObj.exch = request.exch;
                } else {
                    return; //
                }

                // filter by traded value
                if (request.value && request.valueSign) {
                    var value = String(request.value).trim();
                    if (value) {
                        filter.push({field: fieldLValue, value: request.value, comparison: getComparison(request.valueSign)});
                    }
                }
                // filter by volume
                if (request.vol && request.volSign) {
                    var vol = String(request.vol).trim();
                    if (vol) {
                        filter.push({field: fieldUnit, value: request.vol, comparison: getComparison(request.volSign)});
                    }
                }
                
                if (filter.length > 0) {
                    reqObj.filter = filter;
                }

                qcFeed.request(reqObj);
            }

            _addSub(listenId);
        }
    }

