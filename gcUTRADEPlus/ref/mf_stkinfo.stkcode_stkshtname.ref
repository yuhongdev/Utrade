aStkDataList=sStkDataList.split('|')
nStkDataCount=((aStkDataList.length-1)/2)
function SearchStkCodeName_InsertAllIntoListBox(vsCtrlName){
var iCtr,jCtr;var oItem,TheListBox;
TheListBox=document.all(vsCtrlName);
if(TheListBox!=null){
TheListBox.add(document.createElement('OPTION'));
TheListBox.length=nStkDataCount;
for(iCtr=1,jCtr=0;iCtr<nStkDataCount*2;++jCtr){
oItem=TheListBox.options[jCtr];
oItem.value=aStkDataList[iCtr++];
oItem.text=aStkDataList[iCtr++];}}}
function SearchStkCodeName_InsertIntoListBox(vsCtrlName, vsSearchStr){
var iCtr, slen, sTmp;var oItem,TheListBox;
TheListBox=document.all(vsCtrlName);
if(TheListBox!=null){
slen = vsSearchStr.length;
if(slen==0){
SearchStkCodeName_InsertAllIntoListBox(vsCtrlName);
return 0;}
TheListBox.length=0;
sTmp=vsSearchStr.charAt(0);
if(sTmp>='0' && sTmp<='9') {
for(iCtr=1;iCtr<nStkDataCount*2;){
sTmp=aStkDataList[iCtr++];
if (sTmp.substring(0, slen)==vsSearchStr){
oItem=document.createElement('OPTION');
oItem.value=sTmp;
oItem.text=aStkDataList[iCtr];
TheListBox.add(oItem);}
++iCtr;}
} else {
vsSearchStr = vsSearchStr.toUpperCase();
for(iCtr=1;iCtr<nStkDataCount*2;){
sTmp=aStkDataList[iCtr+1];
if (sTmp.substring(0, slen)==vsSearchStr){
oItem=document.createElement('OPTION');
oItem.value=aStkDataList[iCtr];
oItem.text=sTmp;
TheListBox.add(oItem);
} else if (sTmp.substring(0, slen)>vsSearchStr){
break;}
iCtr+=2;}}TheListBox.selectedIndex=0;}}
function SearchStkCodeName(vsSearchStr){
var iCtr, sTmp;
sTmp=vsSearchStr.charAt(0);
if(sTmp>='0' && sTmp<='9') {
for(iCtr=1;iCtr<nStkDataCount*2;){
sTmp=aStkDataList[iCtr++];
if (sTmp==vsSearchStr){
return aStkDataList[iCtr];}
++iCtr;}
} else {
vsSearchStr = vsSearchStr.toUpperCase();
for(iCtr=1;iCtr<nStkDataCount*2;){
sTmp=aStkDataList[iCtr+1];
if (sTmp==vsSearchStr){
return aStkDataList[iCtr];
} else if (sTmp>vsSearchStr){
break;}
iCtr+=2;}}
return "";}
function SearchStkCodeName_CtrlAdd(voCtrl, vsKey, vsValue){
var oItem;
if (voCtrl == null) { return -1; }
voCtrl.value=vsKey;
if (voCtrl.value!=vsKey) {
oItem=document.createElement('OPTION');
oItem.value=vsKey;
oItem.text=vsValue;
voCtrl.add(oItem);
voCtrl.value=vsKey;
} return 0;}
function SearchStkCodeName_CtrlDel(voCtrl, vsKey){
if (voCtrl == null) { return -1; }
voCtrl.value=vsKey;
if (voCtrl.value==vsKey) {
voCtrl.options[voCtrl.selectedIndex]=null;
} return 0;}
