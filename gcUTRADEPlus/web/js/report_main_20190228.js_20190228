		tblRow += "<td class='setOffAmt'  style=' border-right-color: #FFFFFF'>(0.00)</td>"
		tblRow += "<td class='setOffAmtInt'  style=' border-right-color: #FFFFFF'>(0.00)</td>"
	}else{
		tblRow += "<td class='setOffAmt'  style=' border-right-color: #FFFFFF'>(0.00)</td>"	
