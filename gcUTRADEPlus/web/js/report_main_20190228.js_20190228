	tblRow += "<td>"+ data.DocDate +"</td>"
	tblRow += "<td>"+ data.DocNo +"</td>"
	tblRow += "<td>"+ data.Desc +"</td>"
	tblRow += "<td class='Balance'>("+ data.Balance +")</td>"
	tblRow += "<td class='Interest'>("+ data.Amt +")</td>"
